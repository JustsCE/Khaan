import os, sys, json, time, subprocess, traceback, datetime
from pathlib import Path

sys.path.insert(0, os.path.join(os.path.expanduser("~"), ".claude", "brain"))
from engines._shared import BRAIN
from engines.coms_protocol import mark_processed as _coms_mark_processed

GATE = BRAIN / "binaries" / "always-on.bin"
QUEUE = BRAIN / "queue" / "inbox.jsonl"
LOG_DIR = BRAIN / "logger" / "always-on"
TURN_LOG = BRAIN / "logger" / "handler" / "turn_complete.jsonl"
STATE_FILE = BRAIN / "state.json"
CYCLE_RUNNING = BRAIN / "binaries" / "learning-cycle-running.bin"

SELF_PROMPT = "Iterate. Find what matters most. Move on it."

LIVE_SESSION_WINDOW_S = 90
DECISION_INFLIGHT_WINDOW_S = 120

ITER_COUNT_FILE = BRAIN / "binaries" / "always-on-iter-count.bin"
CYCLE_EVERY_N = 10

CHAT_LOG = Path("/var/lib/docker/volumes/brain-viz_brain-data/_data/brain/dashboard/chat.json")
ACTIVE_RECALL = BRAIN / "navigation" / "active-recall.json"
ACTIVE_IDENTITY = BRAIN / "navigation" / "active-identity.json"
ACTIVE_DECISION = BRAIN / "navigation" / "active-decision.json"
DECISION_WAIT_S = 60
CONTEXT_WINDOW_S = 24 * 3600
BRAIN_TASKS_URL = "http://localhost:3001/api/dashboard/brain-tasks"




def get_recent_chat_context():
    if not CHAT_LOG.exists():
        return ""
    try:
        messages = json.loads(CHAT_LOG.read_text())
    except Exception:
        return ""
    now = datetime.datetime.utcnow()
    recent = []
    for m in reversed(messages):
        ts_str = m.get("ts", "")
        ts = None
        for fmt in ("%Y-%m-%dT%H:%M:%S.%fZ", "%Y-%m-%dT%H:%M:%SZ"):
            try:
                ts = datetime.datetime.strptime(ts_str, fmt)
                break
            except Exception:
                continue
        if ts is None:
            continue
        if (now - ts).total_seconds() > CONTEXT_WINDOW_S:
            break
        recent.append(m)
    recent.reverse()
    return "\n\n".join(f"[{m.get('role','?')} @ {m.get('ts','?')}]\n{m.get('text','')[:1500]}" for m in recent)



import urllib.request as _urlreq

def fetch_brain_tasks():
    try:
        with _urlreq.urlopen(BRAIN_TASKS_URL, timeout=5) as r:
            return json.loads(r.read().decode())
    except Exception as e:
        log_event("brain_tasks_fetch_failed", {"error": str(e)[:200]})
        return {"execute": [], "plan": [], "project": []}


def pick_one_task(bt):
    # Priority order: EXECUTE first (autonomous), then PROJECT (multi-round), then PLAN
    # Within each bucket, lowest priority number wins.
    for bucket in ("execute", "project", "plan"):
        items = bt.get(bucket, [])
        if not items:
            continue
        # Skip PROJECT tasks whose status is gated on Teacher or User
        if bucket == "project":
            items = [t for t in items if t.get("projectStatus") not in
                     ("awaiting_teacher", "user_verify_pending", "verified", "done")]
            if not items:
                continue
        items_sorted = sorted(items, key=lambda t: t.get("priority", 9999))
        return bucket, items_sorted[0]
    return None, None


def render_task(bucket, task):
    tags = task.get("tags", [])
    emoji = "\u26a1" if "EXECUTE" in tags else ("\u25c6" if "PROJECT" in tags else "")
    ps = task.get("projectStatus", "")
    ps_part = f" [{ps}]" if ps else ""
    src = task.get("source", "?")
    orig = task.get("originalSource", src)
    title = (task.get("title") or "")[:200]
    desc = (task.get("description") or "")[:400]
    raw = (task.get("rawSnippet") or "")[:300]
    return (
        f"## Your assigned task this iteration\n"
        f"id: {task.get('id')}  source: {src} (origin: {orig})\n"
        f"tag: {','.join(tags)}  bucket: {bucket.upper()}{ps_part}\n"
        f"priority: {task.get('priority')}\n"
        f"title: {emoji} {title}\n"
        f"description: {desc}\n"
        f"raw: {raw}\n"
    )


def select_seed(bucket, task, has_coms):
    if not task:
        base = "Iterate. Find what matters most. Move on it."
        if has_coms:
            base += (
                "\n\nNo Brain Visual task assigned. Review the COMS section above. "
                "If any message warrants action, POST /api/dashboard/tasks/<source>/<id>/promote "
                "(or create a brain task via the dashboard API) and tag it EXECUTE / PLAN / PROJECT / PENDING. "
                "You set priority. Then stop \u2014 the next iteration will pick it up."
            )
        return base

    tags = task.get("tags", [])
    rules = ["Iterate. Find what matters most. Move on it.", "", "This iteration: act on the ONE task assigned above. Rules by tag:"]
    if "EXECUTE" in tags:
        rules += [
            "- \u26a1 EXECUTE: do the work end-to-end NOW. When complete, "
            f"POST http://localhost:3001/api/dashboard/tasks/{task.get('source')}/{task.get('id')}/done with body {{\"actor\":\"khaan\"}}.",
            "- Post a one-paragraph COMS reply to summarize what you did (role=khaan, thread coms-iteration-summary).",
        ]
    elif "PROJECT" in tags:
        ps = task.get("projectStatus", "initialized")
        rules += [
            f"- \u25c6 PROJECT current status: {ps}.",
            "- If status is initialized / draft_1_complete / draft_2_complete: call advance_project with the next round's plan content + notes (notes auto-logs to the iteration report).",
            "- If status is draft_3_complete: call submit_project_review to send to Teacher.",
            "- If status is revision_needed: call revise_project with the new plan + notes addressing the teacher feedback.",
            "- Do NOT call user_verify_project \u2014 that's user-only.",
            "- Do NOT touch tasks at awaiting_teacher or user_verify_pending.",
        ]
    elif "PLAN" in tags:
        rules += [
            "- PLAN: produce the plan (research, design, options). Do NOT execute.",
            "- If scope warrants a project, init_project + first round. Otherwise post the plan as a COMS reply for Justs to review.",
        ]
    else:
        rules.append("- Unknown tag combination. Read the task carefully, decide one action, execute it, report via COMS.")

    if has_coms:
        rules += [
            "",
            "Also: review the COMS section above. If any message contains a new actionable item, "
            "create a Brain Visual task for it (source=brain, your choice of tag and priority). "
            "You prioritize COMS-originated tasks.",
        ]
    return "\n".join(rules)


def compose_rich_prompt(base_prompt):
    coms_context = get_recent_chat_context()
    bt = fetch_brain_tasks()
    bucket, task = pick_one_task(bt)
    seed = select_seed(bucket, task, has_coms=bool(coms_context))

    # Trigger decision/recall/identity engines using whatever signal we have
    trigger_input = ""
    if task:
        trigger_input = f"{task.get('title','')} {task.get('description','')}".strip()
    if not trigger_input and coms_context:
        trigger_input = coms_context
    if not trigger_input:
        return seed  # nothing to enrich

    try:
        from engines.decision import dispatch
        dispatch(trigger_input)
    except Exception as e:
        log_event("dispatch_failed", {"error": str(e)[:200]})

    deadline = time.time() + DECISION_WAIT_S
    while time.time() < deadline:
        if ACTIVE_DECISION.exists() and ACTIVE_RECALL.exists() and ACTIVE_IDENTITY.exists():
            break
        time.sleep(1)

    parts = []
    if coms_context:
        parts.append(f"## Recent COMS conversation (24h rolling window)\n{coms_context}")
    if task:
        parts.append(render_task(bucket, task))
    for name, path in [("Recall", ACTIVE_RECALL), ("Identity", ACTIVE_IDENTITY), ("Decision", ACTIVE_DECISION)]:
        try:
            parts.append(f"## {name}\n{path.read_text()[:3000]}")
        except Exception:
            pass
    parts.append("---\n" + seed)
    return "\n\n".join(parts)


def read_iter_count():
    try:
        return int(ITER_COUNT_FILE.read_text().strip())
    except Exception:
        return 0


def write_iter_count(n):
    ITER_COUNT_FILE.write_text(str(n))


def gate_on():
    try:
        return GATE.read_text().strip() == "1"
    except Exception:
        return False


def live_session_active():
    if not TURN_LOG.exists():
        return False
    try:
        with open(TURN_LOG) as f:
            f.seek(0, 2)
            size = f.tell()
            f.seek(max(0, size - 4096))
            tail = [l for l in f.read().splitlines() if l.strip()]
        if not tail:
            return False
        last = json.loads(tail[-1])
        last_ts = last.get("ts", "")
        if not last_ts:
            return False
        t = datetime.datetime.strptime(last_ts, "%Y-%m-%dT%H:%M:%SZ")
        age = (datetime.datetime.utcnow() - t).total_seconds()
        return age < LIVE_SESSION_WINDOW_S
    except Exception:
        return False


def cycle_in_flight():
    try:
        return CYCLE_RUNNING.read_text().strip() == "1"
    except Exception:
        return False


def decision_in_flight():
    if not STATE_FILE.exists():
        return False
    try:
        st = json.loads(STATE_FILE.read_text())
        nonce = st.get("active_decision_nonce")
        if nonce is None:
            return False
        ts = st.get("last_decision_start_ts", 0)
        age = time.time() - ts
        return age < DECISION_INFLIGHT_WINDOW_S
    except Exception:
        return False


def dequeue_one():
    if not QUEUE.exists():
        return None
    lines = [l for l in QUEUE.read_text().splitlines() if l.strip()]
    if not lines:
        return None
    first = lines[0]
    QUEUE.write_text("\n".join(lines[1:]) + ("\n" if len(lines) > 1 else ""))
    try:
        return json.loads(first)
    except Exception:
        return {"source": "malformed", "prompt": first}


def log_event(event, data):
    LOG_DIR.mkdir(parents=True, exist_ok=True)
    p = LOG_DIR / f"{time.strftime('%Y-%m-%d')}.jsonl"
    with open(p, "a") as f:
        f.write(json.dumps({"ts": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
                            "event": event, **data}) + "\n")


def iteration():
    if live_session_active():
        log_event("iteration_skipped", {"reason": "live_session_active"})
        time.sleep(30)
        return
    if cycle_in_flight():
        log_event("iteration_skipped", {"reason": "cycle_in_flight"})
        time.sleep(15)
        return
    if decision_in_flight():
        log_event("iteration_skipped", {"reason": "decision_in_flight"})
        time.sleep(15)
        return

    # Brain cycle gate: every CYCLE_EVERY_N iterations, run consolidation
    count = read_iter_count()
    if count >= CYCLE_EVERY_N:
        log_event("brain_cycle_trigger", {"iteration_count": count})
        try:
            from engines.brain_cycle import run_cycle
            run_cycle()
            log_event("brain_cycle_complete", {"iteration_count": count})
        except Exception as e:
            log_event("brain_cycle_failed", {"error": str(e)[:500]})
        finally:
            (BRAIN / "binaries" / "learning-cycle-running.bin").write_text("0")
        write_iter_count(0)
        return

    queued = dequeue_one()
    if queued:
        base_prompt = queued["prompt"]
        source = queued.get("source", "queue")
        prompt = compose_rich_prompt(base_prompt)
        if prompt != base_prompt:
            source = source + "+context"
    else:
        # Brain Visual driven iteration
        prompt = compose_rich_prompt(SELF_PROMPT)
        # Source tag reflects what we picked
        try:
            bt = fetch_brain_tasks()
            bucket, task = pick_one_task(bt)
            if task:
                source = f"brain_visual:{bucket}:{task.get('id')}"
            else:
                source = "self+context" if prompt != SELF_PROMPT else "self"
        except Exception:
            source = "self"

    t0 = time.time()
    log_event("iteration_start", {"source": source, "prompt": prompt[:200]})

    env = {**os.environ}
    env.pop("BRAIN_SKIP_HOOKS", None)

    try:
        r = subprocess.run(
            ["claude", "-p", "--model", "opus"],
            input=prompt, capture_output=True, text=True, env=env
        )
        log_event("iteration_complete", {
            "source": source,
            "latency_ms": int((time.time() - t0) * 1000),
            "exit_code": r.returncode,
            "stdout_chars": len(r.stdout),
            "stderr_chars": len(r.stderr),
        })
        # Mark COMS items as processed after handling
        if source == "coms" and queued and queued.get("msg_id"):
            try:
                _coms_mark_processed(queued["msg_id"])
            except Exception:
                pass
        write_iter_count(read_iter_count() + 1)
    except Exception as e:
        log_event("iteration_failed", {
            "source": source, "latency_ms": int((time.time() - t0) * 1000),
            "reason": str(e)[:500]
        })


def main():
    log_event("daemon_start", {"pid": os.getpid()})
    while True:
        try:
            if not gate_on():
                time.sleep(10)
                continue
            iteration()
        except KeyboardInterrupt:
            log_event("daemon_stop", {"reason": "keyboard_interrupt"})
            return
        except Exception as e:
            log_event("loop_error", {"reason": str(e), "trace": traceback.format_exc()[:1000]})
            time.sleep(30)


if __name__ == "__main__":
    main()
